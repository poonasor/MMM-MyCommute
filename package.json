{
  "name": "mmmmycommute",
  "version": "1.1.0",
  "description": "MagicMirror Module for commute traffic times",
  "main": "MMM-MyCommute.js",
  "scripts": {
    "lint:js": "eslint .",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:md",
    "lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix && markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "test": "npm run lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.css": "stylelint --fix",
    "*.md": "markdownlint-cli2 --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qistoph/MMM-MyCommute.git"
  },
  "keywords": [
    "MagicMirror",
    "Module",
    "Traffic",
    "Commute"
  ],
  "author": "Jeff Clarke",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qistoph/MMM-MyCommute/issues"
  },
  "homepage": "https://github.com/qistoph/MMM-MyCommute#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "moment": "^2.29.1",
    "moment-duration-format": "^1.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "markdownlint-cli2": "^0.22.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "overrides": {
    "smol-toml": "^1.6.1"
  }
}
